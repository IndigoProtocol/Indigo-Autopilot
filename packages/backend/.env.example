# CDP Management Bot Configuration

# ===== BOT CONFIGURATION =====
BOT_INTERVAL_MINUTES=2
AUTO_START_BOT=false
BOT_ENABLED=true
BOT_MAX_RETRIES=3
BOT_TIMEOUT=30000

# ===== CARDANO NETWORK CONFIGURATION =====
CARDANO_NETWORK=Mainnet
BLOCKFROST_URL=https://cardano-mainnet.blockfrost.io/api/v0

# ===== MYSQL DATABASE CONFIGURATION =====
# Example MySQL configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=indigo_autopilot
MYSQL_USERNAME=indigo_user
MYSQL_PASSWORD=your_secure_password
MYSQL_CONNECTION_LIMIT=10
MYSQL_ACQUIRE_TIMEOUT=60000
MYSQL_TIMEOUT=60000

# ===== DATABASE CONFIGURATION =====
DB_HOST=your-analytics-db-host
DB_PORT=5432
DB_NAME=your-analytics-db-name
DB_USER=your-db-username
DB_PASSWORD=your-db-password
DB_SSL=true

# ===== SECURITY CONFIGURATION =====
JWT_SECRET=your_jwt_secret_key_2024
ENCRYPTION_KEY=your_management_bot_encryption_key_2024
API_RATE_LIMIT=100
CORS_ORIGIN=http://localhost:3000

# ===== LOGGING CONFIGURATION =====
LOG_LEVEL=info
LOG_PATH=./logs
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5
LOG_DATE_PATTERN=YYYY-MM-DD

# ===== SERVER CONFIGURATION =====
PORT=3000

# ===== USER WALLETS =====
# Wallets added via: npm run setup-wallet add "seed phrase"
WALLET_SEEDPHRASE_1=your_24_word_mnemonic_phrase_goes_here
WALLET_SEEDPHRASE_2=another_24_word_mnemonic_phrase_for_backup
